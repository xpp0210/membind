# MemBind 环境变量配置
# 复制为 .env 后根据实际情况修改

# 数据库路径（默认 data/membind.db）
MEMBIND_DB_PATH=data/membind.db

# 服务端口
MEMBIND_PORT=8901

# Embedding模型
EMBEDDING_DIM=384
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM API（标签提取 + binding评分）
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=glm-4-flash

# 检索权重
SEMANTIC_WEIGHT=0.4
TIME_DECAY_WEIGHT=0.3
IMPORTANCE_WEIGHT=0.3

# Binding评分权重
BINDING_INTENT_WEIGHT=0.4
BINDING_SCENE_WEIGHT=0.3
BINDING_ENTITY_WEIGHT=0.2
BINDING_TIME_WEIGHT=0.1

# 冲突检测阈值
CONFLICT_THRESHOLD=0.85
