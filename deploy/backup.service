[Unit]
Description=MemBind Database Backup
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash %h/projects/membind/scripts/backup.sh
WorkingDirectory=%h/projects/membind
Environment=MEMBIND_DB_PATH=%h/projects/membind/data/membind.db
Environment=MEMBIND_BACKUP_DIR=%h/projects/membind/data/backups
