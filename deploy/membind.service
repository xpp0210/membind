[Unit]
Description=MemBind Agent Memory Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/membind
EnvironmentFile=/opt/membind/.env
ExecStart=/usr/bin/python3 -m uvicorn server:app --host 0.0.0.0 --port 8901
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
